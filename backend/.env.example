# GyanSetu Backend — Environment Variables Template
# Copy this file to backend/.env and fill in real values.
# NEVER commit your real backend/.env to version control.

# JWT Secrets — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
REFRESH_SECRET_KEY=

# Database — leave blank for local SQLite, set for cloud PostgreSQL
DATABASE_URL=

# Cloudinary (File Uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Firebase Admin SDK (Google OAuth)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
